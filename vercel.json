{
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/app",
            "destination": "/app.html"
        },
        {
            "source": "/isefarena",
            "destination": "/isefarena.html"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Permissions-Policy",
                    "value": "camera=(self), microphone=(self), display-capture=(self)"
                }
            ]
        }
    ]
}
